# OPTIMAP environment configuration for native deployment
# Copy to /opt/optimap/app/optimap/.env and customize values
# Ensure file permissions: chmod 600 /opt/optimap/app/optimap/.env

# =============================================================================
# Database Configuration
# =============================================================================
# DATABASE_URL is the single source of truth for the database connection. It is
# used by Django, the OGC API (/ogcapi/ via pygeoapi), and the backup script.
DATABASE_URL=postgis://optimap:CHANGE_THIS_PASSWORD@localhost:5432/optimap

# =============================================================================
# Application Settings
# =============================================================================
# Debug mode - MUST be False in production
OPTIMAP_DEBUG=False

# Comma-separated list of allowed hostnames
OPTIMAP_ALLOWED_HOST=optimap.example.com,localhost

# Base URL for absolute links (no trailing slash)
OPTIMAP_BASE_URL=https://optimap.example.com

# Secret key - generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# NOTE: Uses SECRET_KEY (not OPTIMAP_SECRET_KEY) in settings.py
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# CSRF trusted origins (comma-separated, include protocol)
CSRF_TRUSTED_ORIGINS=https://optimap.example.com

# =============================================================================
# Caching
# =============================================================================
# Cache backend: 'default' (database) or 'dummy' (disabled)
OPTIMAP_CACHE=default

# Cache timeout in seconds
OPTIMAP_CACHE_SECONDS=3600

# =============================================================================
# File Paths
# =============================================================================
# NOTE: STATIC_ROOT is hardcoded to 'static/' relative to working directory
# For native deployment, nginx serves static files from /opt/optimap/static/
# collectstatic must be run from app directory with STATIC_ROOT pointing to /opt/optimap/static/
# This can be done by symlinking: ln -s /opt/optimap/static /opt/optimap/app/static

# Global regions data directory
OPTIMAP_GLOBAL_REGIONS_DATA_DIR=/opt/optimap/cache/regions

# Number of data dumps to retain
OPTIMAP_DATA_DUMP_RETENTION=3

# =============================================================================
# Email Configuration
# =============================================================================
# Backend: django.core.mail.backends.smtp.EmailBackend or django.core.mail.backends.console.EmailBackend
OPTIMAP_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP server settings
OPTIMAP_EMAIL_HOST=smtp.example.com
OPTIMAP_EMAIL_PORT_SMTP=587
OPTIMAP_EMAIL_USE_TLS=True
OPTIMAP_EMAIL_USE_SSL=False
OPTIMAP_EMAIL_HOST_USER=noreply@example.com
OPTIMAP_EMAIL_HOST_PASSWORD=CHANGE_THIS_PASSWORD

# Default from address
OPTIMAP_EMAIL_DEFAULT_FROM=OPTIMAP <noreply@example.com>

# =============================================================================
# Geoextent API Settings
# =============================================================================
# Maximum file size for single file upload (MB)
OPTIMAP_GEOEXTENT_MAX_FILE_SIZE_MB=100

# Maximum total size for batch uploads (MB)
OPTIMAP_GEOEXTENT_MAX_BATCH_SIZE_MB=500

# Maximum size for remote resource downloads (MB)
OPTIMAP_GEOEXTENT_MAX_DOWNLOAD_SIZE_MB=1000

# Number of parallel download workers
OPTIMAP_GEOEXTENT_DOWNLOAD_WORKERS=4

# Request timeout (seconds)
OPTIMAP_GEOEXTENT_TIMEOUT=30

# Default gazetteer: nominatim, geonames, or photon
OPTIMAP_GEOEXTENT_DEFAULT_GAZETTEER=nominatim

# GeoNames username (required if using geonames gazetteer)
# OPTIMAP_GEONAMES_USERNAME=your_username

# =============================================================================
# External Services (Optional)
# =============================================================================
# Zenodo API (for data deposition)
# ZENODO_API_TOKEN=your_zenodo_token
# ZENODO_API_BASE=https://zenodo.org/api
# ZENODO_SANDBOX_DEPOSITION_ID=

# Wikibase/Wikidata integration
# WIKIBASE_API_URL=https://www.wikidata.org/w/api.php
# WIKIBASE_SPARQL_ENDPOINT=https://query.wikidata.org/sparql
# WIKIBASE_USER_AGENT=OPTIMAP Bot

# =============================================================================
# Logging
# =============================================================================
# Application log level: DEBUG, INFO, WARNING, ERROR
OPTIMAP_LOGGING_LEVEL=INFO

# Django framework log level
DJANGO_LOGGING_LEVEL=ERROR
