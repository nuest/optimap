OPTIMAP_DEBUG=False

OPTIMAP_CACHE=default
OPTIMAP_CACHE_SECONDS=3600
OPTIMAP_PAGE_CACHE_LONG=86400   # 24 hours — about, privacy, sitemap XML
OPTIMAP_PAGE_CACHE_SHORT=3600   # 1 hour  — robots.txt, feeds, geoextent, sitemap .gz

CSRF_COOKIE_SECURE=False

OPTIMAP_BASE_URL=...

# DATABASE_URL is the single source of truth for the DB connection, used by
# Django and the OGC API (/ogcapi/ via pygeoapi).
DATABASE_URL=postgis://optimap:optimap@localhost:5432/optimap

OPTIMAP_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
OPTIMAP_EMAIL_HOST=smtp.gmail.com
OPTIMAP_EMAIL_PORT_SMTP=587
OPTIMAP_EMAIL_HOST_USER=...
OPTIMAP_EMAIL_HOST_PASSWORD=...
OPTIMAP_EMAIL_HOST_IMAP=imap.ionos.de
OPTIMAP_EMAIL_PORT_IMAP=993
OPTIMAP_EMAIL_USE_TLS=True
OPTIMAP_EMAIL_IMAP_SENT_FOLDER=""

OPTIMAP_LOGGING_LEVEL=INFO
DJANGO_LOGGING_LEVEL=ERROR

OPTIMAP_DATA_DUMP_RETENTION=3

# Scheduled (Django-Q) task behaviour after the cluster has been down/blocked.
# OPTIMAP_SCHEDULER_CATCH_UP=False (default): each recurring schedule fires once
#   at its next future slot instead of replaying every missed run. Set to True to
#   restore Django-Q's default replay-all-missed-runs behaviour.
# OPTIMAP_SCHEDULED_TASK_CATCHUP_THRESHOLD_MINUTES: a scheduled run that starts
#   more than this many minutes late is logged as a catch-up (missed runs skipped).
#   NOTE: keep this below the smallest recurring interval to avoid spurious notices.
OPTIMAP_SCHEDULER_CATCH_UP=False
OPTIMAP_SCHEDULED_TASK_CATCHUP_THRESHOLD_MINUTES=5

# Default page size for paginated list views (works list, collection pages)
OPTIMAP_PAGE_MAX_ITEMS=50

# Global regions (continents + oceans) loaded by `python manage.py load_global_regions`.
# The loader auto-downloads source data and runs `simplify_ocean_geometries` on first
# run; the tunables below control the simplification pass.
# - TOLERANCE: Shapely .simplify() distance tolerance in degrees (lower = more detail)
# - PERCENTILE: drop the smallest N%% of holes inside polygons (higher = fewer holes kept)
# - DATA_DIR: where downloaded/derived files are cached; default is the command directory
OPTIMAP_OCEAN_SIMPLIFICATION_TOLERANCE=0.05
OPTIMAP_OCEAN_SIMPLIFICATION_PERCENTILE=80.0
OPTIMAP_GLOBAL_REGIONS_DATA_DIR=

# Geometry upload limits (enforced client-side; hard-block prevents silent 413 errors)
OPTIMAP_GEOMETRY_WARN_SIZE_KB=50      # Soft warning threshold per polygon (default 50 KB)
OPTIMAP_GEOMETRY_MAX_UPLOAD_KB=2048   # Hard block threshold for total payload (default 2 MB)

# OpenAlex API key — raises the daily search-query budget from ~100 (anonymous) to ~1 000
# (free key) searches/day. Direct DOI lookups are always free. Get a free key at
# https://openalex.org/settings/api and set it here to avoid 429s during large harvests.
OPTIMAP_OPENALEX_API_KEY=

# OpenAIRE enrichment (second metadata enrichment source besides OpenAlex)
# Token raises the rate limit from 60/hour (anonymous) to 7200/hour — recommended
# when on-harvest enrichment is enabled. Get one at https://develop.openaire.eu/personal-token
OPTIMAP_OPENAIRE_TOKEN=
OPTIMAP_OPENAIRE_HTTP_TIMEOUT=60
OPTIMAP_OPENAIRE_ENRICH_ON_HARVEST=True   # enqueue an OpenAIRE sweep after each harvest
OPTIMAP_OPENAIRE_ENRICH_THROTTLE=60       # seconds between requests; lower to ~1 when a token is set

# Geoextent API Configuration
OPTIMAP_GEOEXTENT_MAX_FILE_SIZE_MB=100
OPTIMAP_GEOEXTENT_TIMEOUT=30
OPTIMAP_GEOEXTENT_MAX_DOWNLOAD_SIZE_MB=1000
OPTIMAP_GEOEXTENT_MAX_BATCH_SIZE_MB=500
OPTIMAP_GEOEXTENT_DOWNLOAD_WORKERS=4
OPTIMAP_GEOEXTENT_DEFAULT_GAZETTEER=nominatim
OPTIMAP_GEOEXTENT_GAZETTEER_TIMEOUT_SECONDS=5
OPTIMAP_GEOEXTENT_GEONAMES_USERNAME=
# NER text extraction (leave blank to use geoextent's default spaCy model)
OPTIMAP_GEOEXTENT_NER_MODEL=
OPTIMAP_GEOEXTENT_NER_GAZETTEER=nominatim

# EO4GEO Body of Knowledge — concept tagging for works
# v9 is the current live version (1212 concepts, verified 2026-06-11).
# Firebase also exposes a "current" alias but we pin explicitly to avoid
# silent drift. Use "v3" etc. to roll back to an older snapshot.
OPTIMAP_BOK_VERSION=v9
OPTIMAP_BOK_API_BASE=https://eo4geo-bok.firebaseio.com
OPTIMAP_BOK_CONCEPT_BASE_URL=https://geospacebok.eu
# Gate: restrict the BoK editor to works in specific collection(s).
# Comma-separated `Collection.identifier` slugs (no spaces).
# *** Empty = BoK editor disabled site-wide *** — set to opt in.
# Example: OPTIMAP_BOK_ENABLED_COLLECTIONS=mountain-wetlands,essd
OPTIMAP_BOK_ENABLED_COLLECTIONS=

WIKIBASE_CONSUMER_TOKEN=your_consumer_token
WIKIBASE_CONSUMER_SECRET=your_consumer_secret
WIKIBASE_ACCESS_TOKEN=your_access_token
WIKIBASE_ACCESS_SECRET=your_access_secret
WIKIBASE_API_URL=https://your-instance.wikibase.cloud/w/api.php

